# Copy to .env and edit. Every value has a sensible default, so the demo runs
# out of the box against a local Ollama install with no changes.

# Provider selection: auto | anthropic | gemini | openai | ollama
# "auto" picks the first available: anthropic -> gemini -> openai -> ollama
LLM_PROVIDER=auto
EMBEDDING_PROVIDER=auto

# ── Anthropic (Claude) ────────────────────────────────────────────────
# ANTHROPIC_API_KEY=sk-ant-...
# ANTHROPIC_MODEL=claude-opus-4-8

# ── Google Gemini (free tier) ─────────────────────────────────────────
# GEMINI_API_KEY=...
# GEMINI_MODEL=gemini-2.5-flash
# GEMINI_EMBEDDING_MODEL=gemini-embedding-001

# ── OpenAI ────────────────────────────────────────────────────────────
# OPENAI_API_KEY=sk-...
# OPENAI_MODEL=gpt-4o-mini
# OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# ── Ollama (local, free — the default) ────────────────────────────────
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=qwen2.5:7b
OLLAMA_EMBEDDING_MODEL=nomic-embed-text

# ── RAG tuning (optional) ─────────────────────────────────────────────
# DENSE_WEIGHT=0.5
# RAG_TOP_K=4
