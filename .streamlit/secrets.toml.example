# Streamlit secrets template.
# Local:  copy to .streamlit/secrets.toml  (gitignored — never commit real keys)
# Cloud:  paste into  Manage app → Settings → Secrets  on share.streamlit.io
#
# The app reads these as if they were environment variables.

LLM_PROVIDER = "gemini"
EMBEDDING_PROVIDER = "gemini"
GEMINI_API_KEY = "your-gemini-key-here"
GEMINI_MODEL = "gemini-2.5-flash"
GEMINI_EMBEDDING_MODEL = "gemini-embedding-001"
